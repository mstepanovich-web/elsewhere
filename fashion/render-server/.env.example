# Elsewhere Fashion — Render Server Environment Variables
PORT=3001

# Fashn.ai (virtual try-on)
FASHN_API_KEY=your_fashn_api_key_here

# Runway ML (image-to-video, animated_still + multi_angle)
RUNWAY_API_KEY=your_runway_api_key_here

# Kling 2.1 Pro via kie.ai (catwalk video)
KLING_API_KEY=your_kie_ai_key_here

# Cloudflare R2 (output storage)
R2_ACCOUNT_ID=your_cf_account_id
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET=elsewhere-fashion
R2_PUBLIC_URL=https://pub.elsewhere.app
